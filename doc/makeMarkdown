# Unicode -> LaTeX inline math for pdflatex (no newunicodechar needed)
UNICODE_TO_LATEX = [
    ("\u03a9", r"$\Omega$"),   # Omega
    ("\u03bc", r"$\mu$"),      # mu
    ("\u00b0", r"$^\circ$"),   # degree
    ("\u00b1", r"$\pm$"),      # plus-minus
    ("\u00d7", r"$\times$"),   # times
    ("\u2264", r"$\le$"),      # le
    ("\u2265", r"$\ge$"),     # ge
]

def unicode_to_latex(text):
    for u, latex in UNICODE_TO_LATEX:
        text = text.replace(u, latex)
    return text

class MakeDocs():

    def __init__(self,infofile):
        self.readOptions(infofile)
