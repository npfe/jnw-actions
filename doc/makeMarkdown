        self.header = """---
layout: page
title: {title}
---

"""

    def _get(self,path,data=None):
        #print(path,data)
        if(data is None):
            return None
        if("." in path):
            arr = path.split(".")
            ndata = self._get(arr[0],data)
            #print(arr[0])
            return self._get(".".join(arr[1:]),ndata)
        elif(path in data):
            return data[path]
        else:
            print(f"Warning: Could not find {path} in {data} ")
            return None


    def doCmdWithReturn(self,cmd):
        result = subprocess.getoutput(cmd)

        return result

