    def _strip_frontmatter(self, text):
        """Remove Jekyll-style --- ... --- block at start of markdown."""
        if not text.strip().startswith("---"):
            return text
        lines = text.split("\n")
        start = 0
        for i, line in enumerate(lines):
            if i > 0 and line.strip() == "---":
                start = i + 1
                break
        return "\n".join(lines[start:])

    def _strip_jekyll_directives(self, text):
        """Remove Kramdown/Jekyll-only directives that have no meaning outside Jekyll
        (auto-TOC markers, attribute lists). Otherwise they render as literal text
        in the combined PDF."""
        out_lines = []
        for line in text.split("\n"):
            s = line.strip()
            # `* TOC` followed (next line) by `{:toc}` is Kramdown's auto-TOC marker.
            if s in ("* TOC", "{:toc}") or re.match(r"^\{:toc\s*\}$", s):
                continue
            # `* TOC {:toc}` on one line.
            if re.match(r"^\*\s*TOC\s*\{:toc\s*\}\s*$", s):
                continue
            out_lines.append(line)
        return "\n".join(out_lines)

    def _schematic_libs(self):
        """Library names that hold schematics — used to recognise schematic images
        by their path prefix in combined.md."""
        libs = self._get("doc.libraries", self.options)
        if isinstance(libs, dict):
            return list(libs.keys())
        return []

    def _doc_sections(self):
        """Return list of (title, path) for docs to combine, in order. Path relative to docdir."""
        order = [
            ("index.md", "Overview"),
            ("install.md", "Install"),
            ("schematic.md", "Schematics"),
            ("layout.md", "Layout"),
            ("simulations.md", "Simulations"),
        ]
        out = []
        for fname, title in order:
            path = self.docdir + os.path.sep + fname
            if os.path.exists(path):
                out.append((title, path))
        return out

    def makeCombinedMarkdown(self):
        """Write combined.md: README (index) + install + schematic + simulations + layout."""
        sections = self._doc_sections()
        if not sections:
            return
        combined_path = self.docdir + os.path.sep + "combined.md"
        with open(combined_path, "w") as fo:
            for i, (title, path) in enumerate(sections):
                with open(path) as fi:
                    content = self._strip_frontmatter(fi.read())
                content = self._strip_jekyll_directives(content)
                if i > 0:
                    fo.write("\n\n---\n\n")
                    fo.write("## " + title + "\n\n")
                else:
                    if content.strip() and not content.lstrip().startswith("#"):
                        fo.write("# " + title + "\n\n")
                fo.write(content.strip())
                fo.write("\n")
        print("INFO: wrote " + combined_path)

    def _svg_to_eps_tool(self):
        """Return (cmd_pattern, ext) for SVG→EPS: cmd_pattern has {src} {dst}. Inkscape only (EPS uses drawing bounds by default)."""
        r = subprocess.run(["which", "inkscape"], capture_output=True, text=True)
        if r.returncode == 0 and r.stdout.strip():
            return ("inkscape {src} --export-type=eps -o {dst}", "eps")
        return (None, "eps")

    def _svg_to_pdf_tool(self):
        """Return (cmd_pattern, ext) for SVG→PDF. Prefer PDF 1.5 for pdflatex compatibility. Try rsvg, inkscape, then ImageMagick."""
        r = subprocess.run(["which", "rsvg-convert"], capture_output=True, text=True)
        if r.returncode == 0 and r.stdout.strip():
            return ("rsvg-convert -f pdf -o {dst} {src}", "pdf")
        r = subprocess.run(["which", "inkscape"], capture_output=True, text=True)
        if r.returncode == 0 and r.stdout.strip():
            return ("inkscape {src} --export-type=pdf --export-pdf-version=1.5 -o {dst}", "pdf")
        if subprocess.run(["which", "magick"], capture_output=True).returncode == 0:
            return ("magick -density 150 -define pdf:version=1.5 {src} {dst}", "pdf")
        if subprocess.run(["which", "convert"], capture_output=True).returncode == 0:
            return ("convert -density 150 -define pdf:version=1.5 {src} {dst}", "pdf")
        return (None, "pdf")

    def _pdf_to_pdf15(self, pdf_path):
        """Re-save PDF as version 1.5 with ghostscript if available. Return True if done or skipped (no gs), False on failure."""
        if not os.path.exists(pdf_path):
            return False
        r = subprocess.run(["which", "gs"], capture_output=True, text=True)
        if r.returncode != 0 or not r.stdout.strip():
            return True  # no gs, skip (caller keeps original)
        tmp = pdf_path + ".tmp.pdf"
        cmd = [
            "gs", "-sDEVICE=pdfwrite", "-dCompatibilityLevel=1.5",
            "-dNOPAUSE", "-dBATCH", "-sOutputFile=" + tmp, pdf_path
        ]
        ret = subprocess.run(cmd, capture_output=True, text=True)
        if ret.returncode == 0 and os.path.exists(tmp):
            os.replace(tmp, pdf_path)
            return True
        if os.path.exists(tmp):
            try:
                os.remove(tmp)
            except OSError:
                pass
        return False

    def _convert_svg_to_fig(self, docdir, src_path, out_dir):
        """Convert one SVG to a figure for LaTeX. Prefer EPS (tight bounding box) when Inkscape is available, else PDF.
        Return path relative to docdir for the figure, or None."""
        if not os.path.isabs(src_path):
            src_abs = os.path.normpath(os.path.join(docdir, src_path))
        else:
            src_abs = src_path
        if not os.path.exists(src_abs) or not src_abs.lower().endswith(".svg"):
            return None
        os.makedirs(out_dir, exist_ok=True)
        path_clean = src_path.split("?")[0].strip().replace("\\", "/")
        if path_clean.lower().endswith(".svg"):
            path_clean = path_clean[:-4]
        safe_name = path_clean.replace("/", "_") if path_clean else "figure"

        # Prefer EPS when available (Inkscape uses drawing bounds by default; PDF export does not).
        tool, ext = self._svg_to_eps_tool()
        if tool:
            out_name = safe_name + ".eps"
            dst_abs = os.path.join(out_dir, out_name)
            cmd = tool.format(src=src_abs, dst=dst_abs)
            ret = os.system(cmd)
            if ret == 0:
                return os.path.relpath(dst_abs, docdir).replace("\\", "/")
        # Fall back to PDF (rsvg, inkscape, or ImageMagick).
        tool, ext = self._svg_to_pdf_tool()
        if not tool:
            print("Warning: no SVG→figure tool (inkscape for EPS, or rsvg-convert/inkscape/ImageMagick for PDF); skip " + src_path)
            return None
        out_name = safe_name + ".pdf"
        dst_abs = os.path.join(out_dir, out_name)
        cmd = tool.format(src=src_abs, dst=dst_abs)
        ret = os.system(cmd)
        if ret != 0:
            print("Warning: conversion failed: " + cmd)
            return None
        # rsvg-convert may output PDF 1.7; downgrade to 1.5 with gs if available (pdflatex compatibility).
        self._pdf_to_pdf15(dst_abs)
        return os.path.relpath(dst_abs, docdir).replace("\\", "/")

    def makeCombinedLatex(self, combined_path=None, out_path=None):
        """Build combined_latex.md from combined.md with SVGs converted to EPS or PDF."""
        docdir = self.docdir
        if combined_path is None:
            combined_path = os.path.join(docdir, "combined.md")
        if not os.path.exists(combined_path):
            print("Warning: combined.md not found; run makeCombinedMarkdown first.")
            return
        media_pdf_dir = os.path.join(docdir, "assets", "media_pdf")
        if out_path is None:
            out_path = os.path.join(docdir, "assets", "combined_latex.md")

        with open(combined_path) as f:
            content = f.read()

        content = self._strip_jekyll_directives(content)

        # Drop the injected "# Overview" heading at the very top — the README
        # content following it carries its own section heading, and the PDF
        # has no use for a duplicate top-level title.
        content = re.sub(r'^\s*#\s+Overview\s*\n+', '', content)

        # Drop GitHub Actions workflow badges and links — they render as a wall
        # of "X workflow" text in the PDF and aren't useful offline.
        workflow_img_re = re.compile(r'!\[[^\]]*\]\([^)]*/actions/workflows/[^)]+\)')
        content = workflow_img_re.sub("", content)
        workflow_link_re = re.compile(r'\[[^\]]*\]\([^)]*/actions/workflows/[^)]+\)')
        content = workflow_link_re.sub("", content)

        # Schematic SVGs live under one of the design libraries; we frame them
        # and force them to fit the page. Other SVGs (FSMs, plots, etc.) just
        # get a width cap so they don't overflow the column.
        sch_libs = self._schematic_libs()

        def _is_schematic(path_rel):
            head = path_rel.split("/", 1)[0]
            return head in sch_libs

        # Find all ![](...svg) or ![...](...svg)
        img_re = re.compile(r'!\[([^\]]*)\]\(([^)]+\.svg)\)')
        replacements = []
        for m in img_re.finditer(content):
            alt, path = m.group(1), m.group(2).strip()
            path_rel = path.split("?")[0].strip()
            fig_rel = self._convert_svg_to_fig(docdir, path_rel, media_pdf_dir)
            if fig_rel:
                if _is_schematic(path_rel):
                    # Raw LaTeX: framed, fits column width and bounded height,
                    # preserving aspect ratio. Blank lines around the block
                    # keep pandoc from wrapping it in a paragraph.
                    new = ("\n\n\\begin{center}\\fbox{\\includegraphics"
                           "[width=0.95\\linewidth,height=0.45\\textheight,"
                           "keepaspectratio]{" + fig_rel + "}}\\end{center}\n\n")
                else:
                    new = "![" + alt + "](" + fig_rel + "){ width=100% }"
                replacements.append((m.group(0), new))
            else:
                replacements.append((m.group(0), "\n[Image: SVG not converted]\n"))
        for old, new in replacements:
            content = content.replace(old, new, 1)

        # Replace remote (http/https) image links with text placeholder so pdflatex
        # does not try to \includegraphics{https://...} (it cannot fetch URLs).
        # Do this BEFORE the raster width cap so we don't decorate a URL we're
        # about to demote to a plain link.
        remote_img_re = re.compile(r'!\[([^\]]*)\]\((https?://[^)]+)\)')
        for m in remote_img_re.finditer(content):
            alt, url = m.group(1), m.group(2)
            placeholder = "\n[Image: %s](%s)\n" % (alt or "remote", url)
            content = content.replace(m.group(0), placeholder, 1)

        # Cap raster image widths (PNG/JPG copied from README etc.) so
        # natively-large images do not run off the page. Skip http(s) URLs
        # (already turned into link placeholders above) and images that
        # already carry a pandoc attribute block.
        raster_re = re.compile(
            r'!\[([^\]]*)\]\((?!https?://)([^)]+\.(?:png|jpg|jpeg|pdf|eps))\)(?!\{)',
            re.IGNORECASE,
        )
        content = raster_re.sub(r'![\1](\2){ width=100% }', content)

        link_placeholder_re = re.compile(r'\[\s*\[Image: SVG not converted\]\s*\]\s*\(([^)]+)\)')
        def _link_sub(m):
            url = m.group(1)
            if "/workflows/" in url:
                label = url.split("/")[-1].replace(".yaml", "").replace(".yml", "")
                return "[%s workflow](%s)" % (label.upper(), url)
            return "[%s](%s)" % (url, url)
        content = link_placeholder_re.sub(_link_sub, content)

        content = unicode_to_latex(content)
        os.makedirs(os.path.dirname(out_path), exist_ok=True)
        with open(out_path, "w") as f:
            f.write(content)
        doc = self.options.get("doc") or {}
        title = self.options.get("title") or doc.get("title") or self.options.get("library")
        if not title and isinstance(doc.get("libraries"), dict):
            libs = list(doc["libraries"].keys())
            if libs:
                title = libs[0]
        title = title or "Documentation"
        title_path = os.path.join(os.path.dirname(out_path), "pdf_title.txt")
        with open(title_path, "w") as tf:
            tf.write(title)
        print("INFO: wrote " + out_path)

    def run_combined_latex(self):
        """Ensure combined.md exists, then build combined_latex.md (SVG→EPS/PDF)."""
        if not os.path.exists(self.docdir + os.path.sep + "combined.md"):
            self.makeCombinedMarkdown()
        self.makeCombinedLatex()

    def copyReadme(self):



        if(not os.path.exists("../README.md")):
            return
        url = "https://github.com/" + self._get("github",self.options) + "/" + self._get("library",self.options).lower()
        rurl = "https://raw.githubusercontent.com/"  + self._get("github",self.options) + "/" + self._get("library",self.options).lower() +  "/refs/heads/main/"
        with open("../docs/index.md","w") as fo:
            fo.write("---\n")
            fo.write("layout: home\n")
            fo.write("---\n\n")
            with open("../README.md") as fi:
                for line in fi:

                    if(re.search("../../actions",line)):
                        line = re.sub("../../actions",f"{url}/actions",line)
                    else:
                        m = re.search(r"!\[[^\]]*\]\(([^\)]+)\)",line)
                        if(m):
                            ourl = m.groups()[0]
                            if(not (ourl.startswith("http://") or ourl.startswith("https://") or ourl.startswith("www") )) :
                                # Copy referenced image into docs/ preserving the relative path
                                # so both Jekyll and pdflatex can resolve it locally. Fall back
                                # to rewriting to the raw GitHub URL if the source is missing.
                                src = os.path.normpath(os.path.join("..", ourl.split("?")[0]))
                                dst = os.path.normpath(os.path.join(self.docdir, ourl.split("?")[0]))
                                if os.path.exists(src):
                                    os.makedirs(os.path.dirname(dst), exist_ok=True)
                                    try:
                                        import shutil
                                        shutil.copy2(src, dst)
                                    except Exception as e:
                                        print(f"Warning: failed to copy {src} -> {dst}: {e}")
                                        line = line.replace("(" + ourl + ")", "(" + rurl+ ourl + ")")
                                else:
                                    print(f"Warning: README image not found locally: {src}; using remote URL")
                                    line = line.replace("(" + ourl + ")", "(" + rurl+ ourl + ")")

                        else:
                            m = re.search(r"\[[^\]]*\]\(([^\)]+)\)",line)
                            if(m):
                                ourl = m.groups()[0]
                                if(not (ourl.startswith("http://") or ourl.startswith("https://") or ourl.startswith("www") )) :
                                    line = line.replace("(" + ourl + ")", "(" + url + "/tree/main/" +   ourl + ")")
                                    line = re.sub("/+","/",line)
                                    line = re.sub("https:/","https://",line)



                    
                    fo.write(line)


    def run(self):

        self.makeInstall()
        self.makeSchematics()
        self.makeGds()
        self.copyReadme()
        self.makeCombinedMarkdown()

        pass

    #- -------- LaTeX / standalone PDF (aic2026-style) --------
    def _latex_config(self):
        """Return doc.latex config dict or None if not configured."""
        return self._get("doc.latex", self.options)

    def _latex_basename(self, path_or_basename):
        """Normalize to file basename without .md (e.g. l00_jayn)."""
        base = path_or_basename.replace("\\", "/").strip()
        if base.endswith(".md"):
            base = base[:-3]
        return os.path.basename(base)

    def _latex_fiximg_name(self, basename):
        """Pandoc/fix_svg style: lowercase, spaces to underscores -> name_fiximg.tex."""
        s = basename.replace("-", " ").replace("_", " ")
        s = "_".join(s.split()).lower()
        return s + "_fiximg.tex"

    def _latex_title_from_config(self, basename):
        titles = self._get("doc.latex.titles", self.options)
        if titles and isinstance(titles, dict) and basename in titles:
            return titles[basename]
        return basename.replace("_", " ")

    def makeLatexCommands(self, run_pandoc=False, run_tex=False, makefile=False):
        """
        Generate pandoc commands and/or full .tex from template.
        Config (doc.latex): template_path, output_dir, sources, bibliography, csl, version_tex, titles.
        """
        cfg = self._latex_config()
        if not cfg:
            print("Warning: doc.latex not set in info file; no LaTeX generation.")
            return

        output_dir = cfg.get("output_dir", "pdf")
        template_path = cfg.get("template_path") or LATEX_DEFAULT_TEMPLATE
        sources = cfg.get("sources") or []
        bibliography = cfg.get("bibliography", "pdf/aic.bib")
        csl = cfg.get("csl", "pdf/ieee-with-url.csl")
        version_tex_path = cfg.get("version_tex")
        version_str = LATEX_VERSION_DEFAULT
        if version_tex_path and os.path.exists(version_tex_path):
            with open(version_tex_path) as f:
                version_str = f.read().strip()

        if not sources:
            print("Warning: doc.latex.sources is empty; nothing to generate.")
            return

        os.makedirs(output_dir, exist_ok=True)
        docdir = getattr(self, "docdir", "../docs")

        for src in sources:
            basename = self._latex_basename(src)
            if not basename:
                continue
            md_path = src if src.endswith(".md") else src + ".md"
            if not os.path.isabs(md_path) and not os.path.exists(md_path):
                alt = os.path.join(docdir, md_path)
                if os.path.exists(alt):
                    md_path = alt
                elif os.path.exists(os.path.join(output_dir, basename + ".md")):
                    md_path = os.path.join(output_dir, basename + ".md")
            if not os.path.exists(md_path):
                print("Warning: skip %s: %s not found." % (basename, md_path))
                continue

            title = self._latex_title_from_config(basename)
            fiximg_tex = self._latex_fiximg_name(basename)
            latex_out = os.path.join(output_dir, basename + ".latex")
            tex_out = os.path.join(output_dir, basename + ".tex")

            pandoc_cmd = (
                "pandoc --citeproc --bibliography=%s --csl=%s -o %s %s"
                % (bibliography, csl, latex_out, md_path)
            )

            if makefile:
                print("\n# %s.tex" % basename)
                print("%s/%s.latex: %s" % (output_dir, basename, md_path))
                print("\t%s" % pandoc_cmd)
                print("# Then: fix images (e.g. fix_svg.py), then fill %s with __title__=%s __file__=%s" % (
                    template_path, title, fiximg_tex.replace(".tex", "")))
                continue

            if run_pandoc:
                print("INFO:", pandoc_cmd)
                ret = os.system(pandoc_cmd)
                if ret != 0:
                    print("Warning: pandoc failed for %s" % basename)
                    continue

            if not run_tex:
                continue

            if not os.path.exists(template_path):
                tpath = os.path.join(output_dir, os.path.basename(template_path))
                if os.path.exists(tpath):
                    template_path = tpath
                else:
                    print("Warning: template not found: %s; skip writing %s" % (template_path, tex_out))
                    continue

            with open(template_path) as f:
                tmpl = f.read()
            filled = (
                tmpl.replace("__title__", title)
                .replace("__file__", fiximg_tex.replace(".tex", ""))
                .replace("__version__", version_str)
            )
            with open(tex_out, "w") as f:
                f.write(filled)
            print("INFO: wrote %s" % tex_out)


@click.group(invoke_without_command=True)
@click.option("--info", default="../info.yaml", help="Default info file")
@click.pass_context
def cli(ctx, info):
    """Generate markdown docs; use 'latex' subcommand for LaTeX/PDF pipeline."""
    if ctx.invoked_subcommand is None:
        ctx.invoke(run, info=info)

@cli.command()
@click.option("--info", default="../info.yaml", help="Default info file")
def run(info):
    """Generate Jekyll-style markdown (install, schematics, simulations, layout)."""
    c = MakeDocs(info)
    c.run()

@cli.command("latex")
@click.option("--info", default="../info.yaml", help="Info file with doc.latex config")
@click.option("--makefile", is_flag=True, help="Print Makefile fragment with pandoc and .tex targets")
@click.option("--run", "run_commands", is_flag=True, help="Run pandoc and write .tex from template")
def latex_cmd(info, makefile, run_commands):
    """
    Generate pandoc commands and/or full .tex from template (aic2026-style).
    Template: e.g. aic2026/pdf/short_tmplt.tex (set doc.latex.template_path in info).
    """
    c = MakeDocs(info)
    c.makeLatexCommands(run_pandoc=run_commands, run_tex=run_commands, makefile=makefile)

@cli.command("combined-latex")
@click.option("--info", default="../info.yaml", help="Info file")
def combined_latex_cmd(info):
    """Build combined_latex.md from combined.md (SVG→EPS/PDF). Run from work/."""
    c = MakeDocs(info)
    c.run_combined_latex()







